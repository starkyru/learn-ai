# ── Module 07b reference service — example configuration ────────────────────
# Copy this file to `.env` and edit it. NEVER commit a real `.env` or real
# credentials. Every value below is a PLACEHOLDER.

# REQUIRED. Which environment this deployment represents.
#   one of: development | staging | production
SERVICE_ENV=development

# Which llm_core / @learn-ai/llm-core provider to use for model calls.
#   one of: openai | anthropic | ollama | nvidia | lmstudio | gemini
# Default is ollama (zero-cost, local). The provider-specific API keys that
# llm_core reads (OPENAI_API_KEY, ANTHROPIC_API_KEY, …) are documented in the
# repository-root .env.example — set them there / in your secret store.
LLM_PROVIDER=ollama

# Optional: override the chat model id (else the provider default is used).
# CHAT_MODEL=

# HTTP port the service listens on (1-65535).
# The Python service defaults to 8000; the TypeScript service to 8001.
PORT=8000

# Path to the SQLite datastore file. Migrations run at startup and /readyz stays
# 503 until they succeed, so the parent directory must exist and be writable. For
# non-Docker local runs, create it first (mkdir -p data). Under Compose this is
# OVERRIDDEN to a mounted-volume path (/app/data or /repo/data).
DB_PATH=data/07b-service.sqlite

# Directory holding the numbered .sql migrations. Leave unset to use the default
# (the module's migrations/ dir); the Docker images set it to the copied-in path.
# MIGRATIONS_DIR=

# How long (seconds) a migration runner waits to acquire the write lock before
# giving up with a clear error. Concurrent runners retry within this deadline
# rather than crashing on SQLITE_BUSY. Non-finite / non-positive / out-of-range
# values fall back to the 30 s default; the effective deadline is capped at 300 s.
# MIGRATION_LOCK_TIMEOUT_S=30

# ── Reliability envelope (enforced around every /ask model call) ────────────
# Per-request deadline that bounds TOTAL time across retries. Python reads
# REQUEST_TIMEOUT_S (seconds); TypeScript reads REQUEST_TIMEOUT_MS (milliseconds).
REQUEST_TIMEOUT_S=30
# REQUEST_TIMEOUT_MS=30000

# Max provider calls allowed in flight at once; excess requests get 503 (busy).
PROVIDER_MAX_CONCURRENCY=8

# Per-identity request budget per 60s window; over-budget requests get 429.
RATE_LIMIT_PER_MINUTE=60

# Retries for a transient provider failure (0 = no retry) before a bounded 502.
PROVIDER_MAX_RETRIES=2

# Circuit breaker: open after this many consecutive provider failures (fast-fail
# 503), then probe again after the cool-off. Python reads CIRCUIT_COOLDOWN_S
# (seconds); TypeScript reads CIRCUIT_COOLDOWN_MS (milliseconds).
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_COOLDOWN_S=30
# CIRCUIT_COOLDOWN_MS=30000

# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# A representative secret the service is configured with. PLACEHOLDER ONLY —
# inject the real value at runtime from your secret store. It is redacted from
# logs and never copied into the image.
PROVIDER_API_KEY=replace-me-with-a-real-secret-at-runtime
