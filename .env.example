# =============================================================================
# learn-ai — environment variables
# Copy to `.env` and fill in the keys for the providers you want to use.
# You do NOT need all of them. Local/Ollama needs no key at all.
# =============================================================================

# --- Default provider for exercises -----------------------------------------
# One of: openai | anthropic | ollama | nvidia
LLM_PROVIDER=ollama

# --- OpenAI ------------------------------------------------------------------
# Get a key: https://platform.openai.com/api-keys  (paid)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic (Claude) ------------------------------------------------------
# Get a key: https://console.anthropic.com/  (paid)
# NOTE: Claude has no embeddings endpoint — use openai/ollama/nvidia for embeddings.
# Cost tip: claude-opus-4-8 is the most capable but pricey. For cheap iteration
# while learning, set ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Ollama (local, free, no key) -------------------------------------------
# Install: https://ollama.com  then `ollama pull llama3.2` and
# `ollama pull nomic-embed-text`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- NVIDIA NIM (build.nvidia.com) ------------------------------------------
# Get a key: https://build.nvidia.com/  (free tier available)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_EMBED_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# --- Vector DBs (used from module 04 onward) --------------------------------
# Qdrant local: `docker run -p 6333:6333 qdrant/qdrant`
QDRANT_URL=http://localhost:6333
# Chroma runs embedded by default (no server needed).

# --- Hosted vision / image generation (modules 09 & 10) ---------------------
# These modules default to HOSTED APIs so nothing huge downloads. Set the key
# for whichever you choose; local PyTorch paths (uv sync --extra vision/imagegen)
# need no key.
# HuggingFace Inference API (vision classification, CLIP, some image gen):
HF_TOKEN=
# Replicate (Stable Diffusion / SDXL — easy hosted image gen):
REPLICATE_API_TOKEN=
# Stability AI (Stable Diffusion):
STABILITY_API_KEY=
# (NVIDIA NIM, set above, also serves some vision + image models.)

# --- Telegram news agent (projects/news-agent) ------------------------------
# Create a bot with @BotFather to get the token; see projects/news-agent/README.md
# for how to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEWS_TOPIC=artificial intelligence
NEWS_POST_HOUR=9
